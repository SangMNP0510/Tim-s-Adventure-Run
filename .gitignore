# This .gitignore is customized for Unity projects using Visual Studio or VS Code.
# It ensures that Assets, Packages, and ProjectSettings are preserved.

### Unity ###
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
[Mm]emoryCaptures/
[Rr]ecordings/

# Autogenerated VS/MD/Consulo solution and project files
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

### Visual Studio Code ###
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.code-workspace
.history/

### Visual Studio ###
.vs/
[Dd]ebug/
[Rr]elease/
*.cache
*.ilk
*.log
*.tlog

### OS Files ###
Thumbs.db
.DS_Store

# Unity auto-generated logs
UpgradeLog.htm
UpgradeLog.htm.meta

### Exceptions ###
# Ensure these folders are always tracked even if a global rule matches them
!/[Aa]ssets/
!/[Pp]ackages/
!/[Pp]rojectSettings/

# Firebase config (DO NOT COMMIT)
Assets/google-services.json
Assets/StreamingAssets/google-services-desktop.json

# Firebase (ignore cả meta)
google-services*.json*

# ================= FIREBASE / ANDROID RESOLVER =================

# Firebase full SDK (không cần commit)
Assets/Firebase/

# Generated từ External Dependency Manager (rất nặng)
Assets/GeneratedLocalRepo/

# Android build artifacts
*.aar
*.srcaar

# iOS / tvOS native libs (to, không cần)
Assets/Plugins/iOS/
Assets/Plugins/tvOS/

# Android native libs (nếu có)
Assets/Plugins/Android/*.aar
Assets/Plugins/Android/*.srcaar

# Firebase native binaries (tránh sót)
*.so
*.bundle
*.a

# ================= OPTIONAL (khuyên dùng) =================

# Gradle build cache
.gradle/

# Unity Android build templates (nếu không custom sâu thì ignore)
# (nếu team bạn có chỉnh thì comment lại)
# Assets/Plugins/Android/mainTemplate.gradle
# Assets/Plugins/Android/settingsTemplate.gradle